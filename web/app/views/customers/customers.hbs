{{>header}}
{{>sidebar}}

<div class="wrapper">
    <a href="/customers/create-customer" class="create-customer-button">Create Customer</a>

    <div class="customers">
        <button onclick="deleteSelectedCustomers()" type="submit">Delete</button>
        <table>
            <thead>
                <tr>
                    <th><input type="checkbox" onchange="checkAllBoxes(this)"></th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Amount Due</th>
                    <th>Created On</th>
                </tr>
            </thead>
            <tbody>
                {{#each customers}}
                    <tr>
                        <td><input class="customer-checkbox box-checkbox" type="checkbox" data-id="{{_id}}"></td>
                        <td><a href="/customers/edit/{{_id}}">{{personal_information.first_name}} {{personal_information.last_name}}</a></td>
                        <td><a href="/customers/edit/{{_id}}">{{personal_information.email}}</a></td>
                        <td><a href="/customers/edit/{{_id}}">placeholder</a></td>
                        <td><a href="/customers/edit/{{_id}}">{{created_on}}</a></td>
                    </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>