{{>header}}
{{>sidebar}}

<div class="wrapper">
    <a href="/items/create-item" class="create-item-button">Create Item</a>

    <div class="items">
        <button onclick="deleteSelectedItems()" type="submit">Delete</button>
        <table>
            <thead>
                <tr>
                    <th><input type="checkbox" onchange="checkAllBoxes(this)"></th>
                    <th>Picture</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                {{#each items}}
                    <tr>
                        <td><input class="item-checkbox box-checkbox" type="checkbox" data-id="{{_id}}"></td>
                        <td><a href="/items/edit/{{_id}}"><img src="/uploads/{{picture}}" width="60px" alt=""></a></td>
                        <td><a href="/items/edit/{{_id}}">{{name}} {{personal_information.last_name}}</a></td>
                        <td><a href="/items/edit/{{_id}}">{{price}}</a></td>
                        <td><a href="/items/edit/{{_id}}">{{description}}</a></td>
                    </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>